<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sk.spse.uloha5.declarative.Controller">
    <center>
        <TableView fx:id="tabulka" prefHeight="267.0" prefWidth="600.0" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="id" prefWidth="50.0" text="ID" />
                <TableColumn fx:id="nazov" minWidth="50.0" prefWidth="300.0" text="Názov" />
                <TableColumn fx:id="kalorie" prefWidth="100.0" text="Kalórie" />
                <TableColumn fx:id="cena" prefWidth="75.0" text="Cena" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
         <BorderPane.margin>
            <Insets left="50.0" right="50.0" />
         </BorderPane.margin>
        </TableView>
    </center>
    <top>
        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Zoznam potravín" textAlignment="CENTER" BorderPane.alignment="CENTER">
            <font>
                <Font size="25.0" />
            </font>
            <BorderPane.margin>
                <Insets bottom="20.0" top="20.0" />
            </BorderPane.margin>
        </Text>
    </top>
    <bottom>
        <HBox id="controls" prefHeight="50.0" prefWidth="100.0" BorderPane.alignment="CENTER">
            <children>
                <Button fx:id="addButton" mnemonicParsing="false" text="Pridaj potravinu">
                    <HBox.margin>
                        <Insets />
                    </HBox.margin>
                </Button>
                <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDelete" text="Vymaž">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </Button>
                <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose" text="Zatvor">
                    <HBox.margin>
                        <Insets left="10.0" />
                    </HBox.margin>
                </Button>
            </children>
         <padding>
            <Insets top="10.0" />
         </padding>
        </HBox>
    </bottom>
</BorderPane>
